<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#7B1FA2"/>
            <stroke android:width="2dp" android:color="#FFD700"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#1A0030"/>
            <stroke android:width="1dp" android:color="#4A148C"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#4A148C"/>
            <stroke android:width="2dp" android:color="#CE93D8"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</selector>
