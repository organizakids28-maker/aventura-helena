<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#EF6C00" />
            <corners android:radius="20dp" />
            <stroke android:width="4dp" android:color="#FFD700" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#BF360C" />
            <corners android:radius="20dp" />
            <stroke android:width="3dp" android:color="#FFD700" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E65100" />
            <corners android:radius="20dp" />
            <stroke android:width="2dp" android:color="#FFB74D" />
        </shape>
    </item>
</selector>
