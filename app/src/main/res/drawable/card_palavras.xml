<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#7B1FA2" />
            <corners android:radius="20dp" />
            <stroke android:width="4dp" android:color="#FFD700" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#4A148C" />
            <corners android:radius="20dp" />
            <stroke android:width="3dp" android:color="#FFD700" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#6A1B9A" />
            <corners android:radius="20dp" />
            <stroke android:width="2dp" android:color="#CE93D8" />
        </shape>
    </item>
</selector>
