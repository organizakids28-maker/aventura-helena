<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0018"
    android:padding="10dp">

    <!-- ═══════════════════════════════════════
         ZONA DE PERSONAGENS
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- ── Helena ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_helena_batalha"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:src="@drawable/helena_avatar"
                android:scaleType="centerCrop"
                android:background="@drawable/profile_bg"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="4dp" />

            <TextView
                android:id="@+id/tv_hp_helena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HELENA 100/100"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="3dp" />

            <ProgressBar
                android:id="@+id/pb_hp_helena"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="100"
                android:progressDrawable="@drawable/pb_helena"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- ── Centro: VS + feedback ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VS"
                android:textColor="#FFD700"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_feedback_batalha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:minHeight="44dp" />

            <TextView
                android:id="@+id/tv_modo_batalha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ataque: Complete a Palavra"
                android:textColor="#CE93D8"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- ── Bruxo ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/ll_bruxo_perfil"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bruxo_bg"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="8dp"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="- - -"
                    android:textColor="#CE93D8"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BRUXO"
                    android:textColor="#E1BEE7"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAS TREVAS"
                    android:textColor="#9C4DCC"
                    android:textSize="11sp"
                    android:gravity="center" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_hp_bruxo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BRUXO 150/150"
                android:textColor="#CE93D8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="3dp" />

            <ProgressBar
                android:id="@+id/pb_hp_bruxo"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="150"
                android:progress="150"
                android:progressDrawable="@drawable/pb_bruxo"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         ÁREA DE JOGO
    ═══════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ── MODO PALAVRA ── -->
        <LinearLayout
            android:id="@+id/ll_modo_palavra"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:visibility="visible">

            <!-- Dica da palavra -->
            <TextView
                android:id="@+id/tv_dica_palavra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AB47BC"
                android:textSize="13sp"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <!-- Letras da palavra (preenchidas dinamicamente) -->
            <LinearLayout
                android:id="@+id/ll_letras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- 4 Botões de opção de letra -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btn_op0"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/btn_op1"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/btn_op2"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action"
                    android:layout_marginRight="6dp" />

                <Button
                    android:id="@+id/btn_op3"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action" />

            </LinearLayout>

            <!-- Botão Magia da Memória -->
            <Button
                android:id="@+id/btn_magia"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Magia da Memoria (acerte 2 palavras)"
                android:textColor="#7A5A80"
                android:textSize="13sp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:enabled="false"
                android:background="@drawable/btn_magia" />

        </LinearLayout>

        <!-- ── MODO MEMÓRIA (magia especial) ── -->
        <LinearLayout
            android:id="@+id/gl_memoria_batalha"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
