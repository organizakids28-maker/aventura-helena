<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A0033"
    android:padding="16dp">

    <!-- Cabeçalho da batalha com HP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <!-- HP da Helena -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HELENA"
                android:textColor="#FFD700"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_hp_helena"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HP: 3/3"
                android:textColor="#4CAF50"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fase atual -->
        <TextView
            android:id="@+id/tv_fase"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FASE 1\nMemoria"
            android:textColor="#CE93D8"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- HP do Inimigo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRUXO"
                android:textColor="#EF5350"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_hp_inimigo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HP: 3/3"
                android:textColor="#EF5350"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Area principal do jogo (muda conforme a fase) -->
    <FrameLayout
        android:id="@+id/fl_jogo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- FASE 1: Grid de memória 2x3 -->
        <GridLayout
            android:id="@+id/grid_batalha"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="3"
            android:rowCount="2"
            android:visibility="visible" />

        <!-- FASE 2: Pergunta de palavras -->
        <LinearLayout
            android:id="@+id/ll_palavras_batalha"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_pergunta_batalha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pergunta 1 de 3"
                android:textColor="#CE93D8"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_palavra_batalha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="G _ T O"
                android:textColor="#FFD700"
                android:textSize="44sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_bat0"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action"
                    android:layout_marginRight="8dp" />

                <Button
                    android:id="@+id/btn_bat1"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action"
                    android:layout_marginRight="8dp" />

                <Button
                    android:id="@+id/btn_bat2"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action"
                    android:layout_marginRight="8dp" />

                <Button
                    android:id="@+id/btn_bat3"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@drawable/btn_action" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Mensagem de resultado -->
    <TextView
        android:id="@+id/tv_resultado_batalha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="8dp" />

</LinearLayout>
