<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1A0033"
    android:padding="20dp">

    <!-- PAINEL ESQUERDO: Perfil da Helena -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#2D0052"
        android:padding="24dp"
        android:layout_marginRight="16dp">

        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AVENTURA DA HELENA"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#x2728;"
            android:textSize="64sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_nivel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nivel 1 - Exploradora"
            android:textColor="#CE93D8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/pb_xp"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#FFD700"
            android:progressBackgroundTint="#4A148C"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_xp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 XP"
            android:textColor="#E1BEE7"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F9E0;"
                    android:textSize="28sp" />
                <TextView
                    android:id="@+id/tv_int"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intel."
                    android:textColor="#CE93D8"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F3AF;"
                    android:textSize="28sp" />
                <TextView
                    android:id="@+id/tv_foc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Foco"
                    android:textColor="#CE93D8"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F3E0;"
                    android:textSize="28sp" />
                <TextView
                    android:id="@+id/tv_res"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resp."
                    android:textColor="#CE93D8"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- PAINEL DIREITO: Botões de ação -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_memoria"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Memoria"
            android:textColor="#1A0033"
            android:textSize="22sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/btn_action"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_palavras"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Palavras"
            android:textColor="#1A0033"
            android:textSize="22sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/btn_action"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_tarefas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Tarefas"
            android:textColor="#1A0033"
            android:textSize="22sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/btn_action"
            android:layout_marginBottom="16dp" />

        <!-- Checklist de desbloqueio da batalha -->
        <TextView
            android:id="@+id/tv_checklist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#E1BEE7"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Botão da batalha (visível apenas quando desbloqueado) -->
        <Button
            android:id="@+id/btn_batalha"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="BATALHAR!"
            android:textColor="#FFD700"
            android:textSize="26sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/btn_battle"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
