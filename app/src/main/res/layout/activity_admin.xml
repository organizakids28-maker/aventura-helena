<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A0033">

    <!-- ══════════════════════════════════════════
         TELA DE PIN
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_pin_entry"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="visible">

        <!-- Lado esquerdo: título + display de PIN -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MODO ADMINISTRADOR"
                android:textColor="#FFD700"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Digite a senha de 4 digitos:"
                android:textColor="#CE93D8"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <!-- Caixas do PIN -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_pin_d1"
                    android:layout_width="64dp"
                    android:layout_height="72dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/pin_box"
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tv_pin_d2"
                    android:layout_width="64dp"
                    android:layout_height="72dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/pin_box"
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tv_pin_d3"
                    android:layout_width="64dp"
                    android:layout_height="72dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/pin_box"
                    android:layout_marginRight="10dp" />

                <TextView
                    android:id="@+id/tv_pin_d4"
                    android:layout_width="64dp"
                    android:layout_height="72dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/pin_box" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_erro_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Senha incorreta. Tente novamente."
                android:textColor="#EF5350"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Lado direito: teclado numérico -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_n1" android:layout_width="82dp" android:layout_height="72dp" android:text="1" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n2" android:layout_width="82dp" android:layout_height="72dp" android:text="2" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n3" android:layout_width="82dp" android:layout_height="72dp" android:text="3" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_n4" android:layout_width="82dp" android:layout_height="72dp" android:text="4" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n5" android:layout_width="82dp" android:layout_height="72dp" android:text="5" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n6" android:layout_width="82dp" android:layout_height="72dp" android:text="6" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_n7" android:layout_width="82dp" android:layout_height="72dp" android:text="7" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n8" android:layout_width="82dp" android:layout_height="72dp" android:text="8" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n9" android:layout_width="82dp" android:layout_height="72dp" android:text="9" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Button android:id="@+id/btn_del" android:layout_width="82dp" android:layout_height="72dp" android:text="DEL" android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_dificil" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_n0" android:layout_width="82dp" android:layout_height="72dp" android:text="0" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_action" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginRight="8dp" />
                <Button android:id="@+id/btn_entrar" android:layout_width="82dp" android:layout_height="72dp" android:text="OK" android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/btn_facil" android:focusable="true" android:focusableInTouchMode="true" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         PAINEL DO ADMINISTRADOR
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_painel_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="20dp"
        android:visibility="gone">

        <!-- Coluna esquerda: estatísticas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/profile_bg"
            android:padding="20dp"
            android:layout_marginRight="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PAINEL DO ADMINISTRADOR"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_admin_stats"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:textColor="#E1BEE7"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Coluna direita: botões de ação -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btn_resetar_dia"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="Resetar Dia (jogos + tarefas)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/btn_selector"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_limpar_batalha"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="Liberar Batalha de Hoje"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/btn_action"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_resetar_tudo"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="RESETAR TODO O PROGRESSO"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/btn_dificil"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btn_voltar_admin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Sair do Admin"
                android:textColor="#CE93D8"
                android:textSize="15sp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@drawable/bruxo_bg" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
